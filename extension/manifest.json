{
  "manifest_version": 3,
  "name": "CaMaGaRe — Descarga SRI",
  "version": "1.16.1",
  "description": "Envía tus comprobantes recibidos del portal del SRI al sistema CaMaGaRe con un clic.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "cookies"],
  "host_permissions": [
    "https://*.sri.gob.ec/*",
    "https://erp.camagare.com.ec/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://srienlinea.sri.gob.ec/comprobantes-electronicos-internet/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.sri.gob.ec/*"],
      "js": ["content_login.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://erp.camagare.com.ec/*", "http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content_sistema.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Descarga SRI → CaMaGaRe",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
